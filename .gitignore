# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/Assets/StreamingAssets/Assembly*
/ios/

# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data
/[Mm]emoryCaptures/

# Recordings can get excessive in size
/[Rr]ecordings/

# Hybrid
/Release-Win64
/Release-Win32
/Release-Android
/HybridCLRData/
/HybridCLRData/AssembliesPostIl2CppStrip/
/HybridCLRData/HotUpdateDlls/
/HybridCLRData/hybridclr_repo/
/HybridCLRData/il2cpp_plus_repo/
/HybridCLRData/iOSBuild/
/HybridCLRData/LocalIl2CppData-WindowsEditor/
/HybridCLRData/StrippedAOTDllsTempProj/
/Assets/Res/hotupdate_assembly/*.dll.bytes
/Assets/Res/hotupdate_assembly/*.dll.bytes.meta
/Assets/Res/hotupdate_assembly.meta

# Uncomment this line if you wish to ignore the asset store tools plugin
# /[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
/[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio cache directory
.vs/
.vsconfig
.vscode

# Gradle cache directory

# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.idea/

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app
*.DS_Store

# Crashlytics generated file
crashlytics-build.properties

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Packed AssetBundles
/android_ab/
/ios_ab/
/windows_ab/
/AllAndroidPatchFiles/
/Assets/StreamingAssets/src/
/AndroidGradleProject/launcher/
/AndroidGradleProject/unityLibrary/
/AndroidGradleProject/.gradle/
/AndroidGradleProject/gradle.properties
/AndroidGradleProject/local.properties
/Assets/1111111111/*
/Assets/1111111111.meta
/Assets/ThridPart/TexturePacker/Editor/SettingsTexturePackerImporter.txt
/Assets/ThridPart/TexturePacker/Editor/SettingsTexturePackerImporter.txt.meta
/AppConfig.json

# Temporary auto-generated Android Assets
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*
/Assets/Res/updater/script/emmylua.lua.txt
/Assets/Res/updater/script/emmylua.lua.txt.meta
Assets/Res/fantasy3d/res/LobbySession/UITexture/Atlas/img_off.png
Assets/Res/fantasy3d/res/LobbySession/UITexture/Atlas/img_off.png.meta
